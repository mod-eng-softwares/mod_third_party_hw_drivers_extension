project_name: mikroe_pcr_xm125
package: platform
label: Third Party Hardware Drivers - XM125 - PCR Click (Mikroe)
description: |
  This example project shows an example for Mikroe PCR Click board driver integration.
category: Example|Platform
quality: evaluation

filter:
  - name: Device Type
    value: [SoC]
  - name: MCU
    value: [32-bit MCU]
  - name: Project Difficulty
    value: [Beginner]

source:
  - path: app.c

include:
  - path: ''
    file_list:
    - path: app.h

component:
  - id: sl_main
  - id: syscalls
    from: wiseconnect3_sdk
  - id: si91x_memory_default_config
    from: wiseconnect3_sdk
  - id: i2c_instance
    instance: [i2c2]
    from: wiseconnect3_sdk
  - id: app_assert
  - id: sleeptimer
  - id: mikroe_pcr_xm125
    from: third_party_hw_drivers

sdk_extension:
  - id: third_party_hw_drivers
    version: 4.4.0
  - id: wiseconnect3_sdk
    version: 3.5.0

configuration:
  - name: SL_ULP_I2C_SCL_PORT
    value: "HP"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SCL_PIN
    value: "7"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SCL_LOC
    value: "9"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SDA_PORT
    value: "HP"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SDA_PIN
    value: "6"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SDA_LOC
    value: "13"
    condition: [brd2708a]
  - name: SL_UART1_DMA_CONFIG_ENABLE
    value: "0"
    unless: [brd2708a]

readme:
  - path: ../../documentation/example/mikroe_pcr_xm125/README.md

other_file:
  - path: ../../documentation/example/mikroe_pcr_xm125/image/create_example.png
    directory: image
  - path: ../../documentation/example/mikroe_pcr_xm125/image/hardware_connection.png
    directory: image
  - path: ../../documentation/example/mikroe_pcr_xm125/image/console_log.png
    directory: image

ui_hints:
  highlight:
    - path: README.md
      focus: true

post_build:
  path: ../../../utilities/postbuild_profile/wiseconnect_soc.slpb
