project_name: ezurio_lora_rm126x
package: platform
label: Third Party Hardware Drivers - RM126x - LoRa Module (Ezurio)
description: |
  This example project shows an example for RM126x - LoRa Module (Ezurio) driver integration.
category: Example|Platform
quality: evaluation

filter:
  - name: Device Type
    value: [SoC]
  - name: MCU
    value: [32-bit MCU]
  - name: Project Difficulty
    value: [Beginner]

source:
  - path: app.c

include:
  - path: ''
    file_list:
    - path: app.h

component:
  - id: sl_main
  - id: device_init
  - id: clock_manager
  - id: iostream
  - id: iostream_eusart
    instance: [vcom]
  - id: iostream_usart
    instance: [ezurio]
  - id: sleeptimer
  - id: app_log
  - id: simple_button
    instance: [btn0]
  - id: simple_led
    instance: [led0]
  - id: ezurio_lora_rm126x
    from: third_party_hw_drivers

config_file:
  - path: ./config/brd4186c/sl_iostream_usart_ezurio_config.h
    override:
      component: iostream_usart
      file_id: iostream_usart_config
      instance: ezurio

configuration:
- name: SL_BOARD_ENABLE_VCOM
  value: '1'

sdk_extension:
  - id: third_party_hw_drivers
    version: 4.4.1

readme: 
  - path: ../../documentation/example/ezurio_lora_rm126x/README.md

other_file:
  - path: ../../documentation/example/ezurio_lora_rm126x/image/create_example.png
    directory: "image"

ui_hints:
  highlight:
  - path: README.md
    focus: true