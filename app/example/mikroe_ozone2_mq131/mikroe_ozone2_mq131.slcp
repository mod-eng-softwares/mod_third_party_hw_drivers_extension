project_name: mikroe_ozone2_mq131
label: Third Party Hardware Drivers - MQ131 - Ozone 2 Click (Mikroe)
package: platform
description: |
  This example project shows an example for Ozone 2 Click board driver integration.
category: Example|Platform
quality: evaluation

filter:
  - name: Device Type
    value: [SoC]
  - name: MCU
    value: [32-bit MCU]
  - name: Project Difficulty
    value: [Beginner]

source:
  - path: app.c

include:
  - path: ''
    file_list:
    - path: app.h

component:
  - id: sl_main
  - id: device_init
  - id: clock_manager
  - id: app_log
  - id: iostream_eusart
    instance: [vcom]
  - id: spidrv
    instance: [mikroe]
  - id: mikroe_ozone2
    from: third_party_hw_drivers

configuration:
  - name: SL_SPIDRV_MIKROE_CS_CONTROL
    value: "spidrvCsControlApplication"

sdk_extension:
  - id: third_party_hw_drivers
    version: 4.4.1

readme:
  - path: ../../documentation/example/mikroe_ozone2_mq131/README.md

other_file:
  - path: ../../documentation/example/mikroe_ozone2_mq131/image/create_example.png
    directory: image
  - path: ../../documentation/example/mikroe_ozone2_mq131/image/hardware_connection.png
    directory: image
  - path: ../../documentation/example/mikroe_ozone2_mq131/image/log.png
    directory: image

ui_hints:
  highlight:
    - path: README.md
      focus: true
