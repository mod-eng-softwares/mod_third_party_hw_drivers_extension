project_name: mikroe_rgb_driver
package: platform
label: Third Party Hardware Drivers - RGB Driver Click (Mikroe)
description: |
  This example project shows an example for Mikroe RGB Driver Click board integration.
category: Example|Platform
quality: evaluation

filter:
  - name: Device Type
    value: [SoC]
  - name: MCU
    value: [32-bit MCU]
  - name: Project Difficulty
    value: [Beginner]

source:
  - path: app.c

include:
  - path: ''
    file_list:
    - path: app.h

component:
  - id: sl_main
  - id: syscalls
    from: wiseconnect3_sdk
  - id: si91x_memory_default_config
    from: wiseconnect3_sdk
  - id: i2c_instance
    instance: [i2c2]
    from: wiseconnect3_sdk
  - id: sleeptimer
  - id: mikroe_rgbdriver
    from: third_party_hw_drivers

sdk_extension:
  - id: third_party_hw_drivers
    version: 4.4.1
  - id: wiseconnect3_sdk
    version: 3.5.2

configuration:
  - name: SL_ULP_I2C_SCL_PORT
    value: HP
    condition:
      - brd2708a
  - name: SL_ULP_I2C_SCL_PIN
    value: 7
    condition:
      - brd2708a
  - name: SL_ULP_I2C_SCL_LOC
    value: 9
    condition:
      - brd2708a
  - name: SL_ULP_I2C_SDA_PORT
    value: HP
    condition:
      - brd2708a
  - name: SL_ULP_I2C_SDA_PIN
    value: 6
    condition:
      - brd2708a
  - name: SL_ULP_I2C_SDA_LOC
    value: 13
    condition:
      - brd2708a
      
readme:
  - path: ../../documentation/example/mikroe_rgb_driver/README.md

other_file:
  - path: ../../documentation/example/mikroe_rgb_driver/image/create_example.png
    directory: "image"
  - path: ../../documentation/example/mikroe_rgb_driver/image/hardware_connection.png
    directory: "image"

ui_hints:
  highlight:
    - path: README.md
      focus: true

post_build:
  path: ../../../utilities/postbuild_profile/wiseconnect_soc.slpb
