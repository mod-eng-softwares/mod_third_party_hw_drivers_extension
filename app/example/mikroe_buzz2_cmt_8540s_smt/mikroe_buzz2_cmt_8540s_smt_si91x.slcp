project_name: mikroe_buzz2_cmt_8540s_smt
package: platform
label: Third Party Hardware Drivers - CMT-8540S-SMT - Buzz 2 Click (Mikroe)
description: |
  This example project shows an example for Mikroe Buzz 2 Click board driver integration.
category: Example|Platform
quality: evaluation

filter:
  - name: Device Type
    value: [SoC]
  - name: MCU
    value: [32-bit MCU]
  - name: Project Difficulty
    value: [Beginner]

source:
  - path: app.c

include:
  - path: ''
    file_list:
    - path: app.h

component:
  - id: sl_main
  - id: syscalls
    from: wiseconnect3_sdk
  - id: si91x_memory_default_config
    from: wiseconnect3_sdk
  - id: pwm_instance
    instance: [channel_0]
    condition: [brd2605a]
    from: wiseconnect3_sdk
  - id: pwm_instance
    instance: [channel_0]
    condition: [brd4338a]
    from: wiseconnect3_sdk
  - id: pwm_instance
    instance: [channel_3]
    condition: [brd2708a]
    from: wiseconnect3_sdk
  - id: sleeptimer
  - id: mikroe_buzz2
    from: third_party_hw_drivers

configuration:
  - name: SL_PWM_OUT_CHANNEL3_3L_PORT
    value: HP
    condition:
      - brd2708a
  - name: SL_PWM_OUT_CHANNEL3_3L_PIN
    value: 12
    condition:
      - brd2708a
  - name: SL_PWM_OUT_CHANNEL3_3L_LOC
    value: 14
    condition:
      - brd2708a
  - name: SL_PWM_CHANNEL_3_POLARITY_LOW
    value: SL_POLARITYL_LOW
    condition:
      - brd2708a
  - name: SL_PWM_COMMON_TIMER_SELECTION
    value: SL_BASE_TIMER_EACH_CHANNEL_VAL
    condition:
      - brd2708a

sdk_extension:
  - id: third_party_hw_drivers
    version: 4.4.0
  - id: wiseconnect3_sdk
    version: 3.5.0

readme:
  - path: ../../documentation/example/mikroe_buzz2_cmt_8540s_smt/README.md

other_file:
  - path: ../../documentation/example/mikroe_buzz2_cmt_8540s_smt/image/create_example.png
    directory: "image"
  - path: ../../documentation/example/mikroe_buzz2_cmt_8540s_smt/image/log.png
    directory: "image"
  - path: ../../documentation/example/mikroe_buzz2_cmt_8540s_smt/image/hardware_connection.png
    directory: "image"
  - path: ../../documentation/example/mikroe_buzz2_cmt_8540s_smt/image/pwm_config.png
    directory: "image"

ui_hints:
  highlight:
    - path: README.md
      focus: true

post_build:
  path: ../../../utilities/postbuild_profile/wiseconnect_soc.slpb
