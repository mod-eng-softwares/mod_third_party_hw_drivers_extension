project_name: sparkfun_hc_sr04_rcwl_9610a
label: Third Party Hardware Drivers - HC-SR04 (RCWL-9610A design)
package: platform
description: |
  This example project shows an example for HC-SR04 (RCWL-9610A design) driver integration.
category: Example|Platform
quality: evaluation

filter:
  - name: Device Type
    value: [SoC]
  - name: MCU
    value: [32-bit MCU]
  - name: Project Difficulty
    value: [Beginner]

source:
  - path: app.c

include:
  - path: ''
    file_list:
    - path: app.h

component:
  - id: sl_main
  - id: syscalls
    from: wiseconnect3_sdk
  - id: si91x_memory_default_config
    from: wiseconnect3_sdk
  - id: sleeptimer
  - id: i2c_instance
    instance: [i2c2]
    from: wiseconnect3_sdk
  - id: sl_si91x_button_917
    instance: [btn0]
    from: wiseconnect3_sdk
  - id: sparkfun_hc_sr04_rcwl_9610a
    from: third_party_hw_drivers

configuration:
  - name: SL_USART0_DMA_CONFIG_ENABLE
    value: 0
  - name: SL_USART0_TX_PORT
    value: ULP
    condition: [brd2708a]
  - name: SL_USART0_TX_PIN
    value: 7
    condition: [brd2708a]
  - name: SL_USART0_TX_LOC
    value: 8
    condition: [brd2708a]
  - name: SL_USART0_RX_PORT
    value: ULP
    condition: [brd2708a]
  - name: SL_USART0_RX_PIN
    value: 6
    condition: [brd2708a]
  - name: SL_USART0_RX_LOC
    value: 13
    condition: [brd2708a]
  - name: SL_ULP_I2C_SCL_PORT
    value: "HP"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SCL_PIN
    value: "7"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SCL_LOC
    value: "9"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SDA_PORT
    value: "HP"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SDA_PIN
    value: "6"
    condition: [brd2708a]
  - name: SL_ULP_I2C_SDA_LOC
    value: "13"
    condition: [brd2708a]

toolchain_settings:
  - option: gcc_linker_option
    value: "-u _printf_float"

sdk_extension:
  - id: third_party_hw_drivers
    version: 4.4.1
  - id: wiseconnect3_sdk
    version: 3.5.0

other_file:
  - path: ../../documentation/example/sparkfun_hc_sr04_rcwl_9610a/image/result.png
    directory: "image"
  - path: ../../documentation/example/sparkfun_hc_sr04_rcwl_9610a/image/create_proj.png
    directory: "image"

readme:
  - path: ../../documentation/example/sparkfun_hc_sr04_rcwl_9610a/README.md

ui_hints:
  highlight:
    - path: README.md
      focus: true

post_build:
  path: ../../../utilities/postbuild_profile/wiseconnect_soc.slpb