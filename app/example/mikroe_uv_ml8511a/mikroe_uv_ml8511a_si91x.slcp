project_name: mikroe_uv_ml8511a
label: Third Party Hardware Drivers - ML8511A - UV Click (Mikroe)
package: platform
description: |
  This example project shows an example for Third Party Hardware Drivers - ML8511A - UV Click (Mikroe) integration.
category: Example|Platform
quality: evaluation

filter:
  - name: Device Type
    value: [SoC]
  - name: MCU
    value: [32-bit MCU]
  - name: Project Difficulty
    value: [Beginner]

source:
  - path: app.c

include:
  - path: ''
    file_list:
    - path: app.h

component:
  - id: sl_main
  - id: syscalls
    from: wiseconnect3_sdk
  - id: si91x_memory_default_config
    from: wiseconnect3_sdk
  - id: adc_instance
    instance: [channel_1]
    from: wiseconnect3_sdk
  - id: sleeptimer
  - id: mikroe_uv
    from: third_party_hw_drivers

configuration:
  - name: SL_ADC_CH1_P_PORT
    value: HP
    condition:
      - brd2708a
  - name: SL_ADC_CH1_P_PIN
    value: 29
    condition:
      - brd2708a
  - name: SL_ADC_CH1_P_LOC
    value: 8
    condition:
      - brd2708a

sdk_extension:
  - id: third_party_hw_drivers
    version: 4.4.0
  - id: wiseconnect3_sdk
    version: 3.5.0

toolchain_settings:
  - option: gcc_linker_option
    value: "-u _printf_float"

readme:
  - path: ../../documentation/example/mikroe_uv_ml8511a/README.md

other_file:
  - path: ../../documentation/example/mikroe_uv_ml8511a/image/hardware_connection.png
    directory: image
  - path: ../../documentation/example/mikroe_uv_ml8511a/image/create_example.png
    directory: image
  - path: ../../documentation/example/mikroe_uv_ml8511a/image/result.png
    directory: image
  - path: ../../documentation/example/mikroe_uv_ml8511a/image/float.png
    directory: image

ui_hints:
  highlight:
    - path: README.md
      focus: true

post_build:
  path: ../../../utilities/postbuild_profile/wiseconnect_soc.slpb