project_name: mikroe_flash8_gd5f2g
package: platform
label: Third Party Hardware Drivers - GD5F2G - Flash 8 Click (Mikroe)
description: |
  This example project shows an example for Flash 8 Click board driver integration using SPI communication.
category: Example|Platform
quality: evaluation

filter:
  - name: Device Type
    value: [SoC]
  - name: MCU
    value: [32-bit MCU]
  - name: Project Difficulty
    value: [Beginner]

source:
  - path: app.c
  - path: spi_nand_example_efx.c

include:
  - path: ''
    file_list:
    - path: app.h
    - path: spi_nand_example.h

component:
  - id: sl_main
  - id: app_assert
  - id: device_init
  - id: clock_manager
  - id: iostream_eusart
    instance: [vcom]
  - id: app_log
  - id: sleeptimer
  - id: services_mikroe_peripheral_drivers_spi_usart_efx
    from: third_party_hw_drivers
  - id: mikroe_flash8_gd5f2g
    from: third_party_hw_drivers

define:
  - name: DEBUG_EFM

sdk_extension:
  - id: third_party_hw_drivers
    version: 4.4.1

readme:
  - path: ../../documentation/example/mikroe_flash8_gd5f2g/README.md

other_file:
  - path: ../../documentation/example/mikroe_flash8_gd5f2g/image/hardware_connection.png
    directory: "image"
  - path: ../../documentation/example/mikroe_flash8_gd5f2g/image/create_example.png
    directory: "image"
  - path: ../../documentation/example/mikroe_flash8_gd5f2g/image/memory_map.png
    directory: "image"
  - path: ../../documentation/example/mikroe_flash8_gd5f2g/image/result.png
    directory: "image"

ui_hints:
  highlight:
    - path: README.md
      focus: true
